{
  "manifest_version": 3,
  "name": "QuickRec",
  "version": "1.0.0",
  "description": "Record screen and upload to Cloudinary.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "QuickRec - Screen Recorder"
  }
}
